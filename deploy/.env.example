# Copy to `.env` and fill in. Read by docker-compose.yml.

# The public URL the server is reached at. Drives Better Auth's baseURL, Secure cookies,
# the OAuth issuer, and the MCP resource audience, so it must match how clients reach you.
# Local trial: http://localhost:8787. Production: your real https URL (behind a reverse
# proxy). No trailing slash.
DESK_PUBLIC_URL=http://localhost:8787

# Required. Stable random secret that signs auth sessions. Generate with:
#   openssl rand -base64 33
# If it changes, everyone is logged out (data is unaffected).
BETTER_AUTH_SECRET=

# Host path bind-mounted to /data (your Markdown + the derived .desk/auth.sqlite + index).
# Defaults to ./data next to this compose file.
DESK_DATA_DIR=./data

# Host port to publish the server on. Default 8787.
DESK_PORT=8787

# Optional. Extra origins to trust (comma-separated), for native development only: set to
# http://localhost:3001 to log in from `npm run tauri:dev` against this server. Leave blank
# otherwise — the built desktop app (tauri://localhost) is trusted without it.
DESK_TRUSTED_ORIGINS=
