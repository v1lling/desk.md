{
  "name": "desk-md-monorepo",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/app",
    "packages/server"
  ],
  "scripts": {
    "dev": "npm run dev -w @desk/app",
    "build": "npm run build -w @desk/app",
    "preview": "npm run preview -w @desk/app",
    "lint": "npm run lint -w @desk/app",
    "typecheck": "tsc --noEmit -p packages/core && tsc --noEmit -p packages/app && tsc --noEmit -p packages/server",
    "screenshots": "node scripts/screenshots.mjs",
    "screenshots:banner": "node scripts/screenshots.mjs --banner-only",
    "tauri": "npm run tauri -w @desk/app",
    "tauri:dev": "npm run tauri:dev -w @desk/app",
    "tauri:build": "npm run tauri:build -w @desk/app",
    "dev:server": "npm run dev -w @desk/server"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/node": "^22"
  }
}
